{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  packageRules: [
    {
      matchPackageNames: ["org.jetbrains.kotlin.plugin.serialization:org.jetbrains.kotlin.plugin.serialization.gradle.plugin"],
      matchUpdateTypes: ["major", "minor"],
      enabled: false,
    },
    {
      matchPackageNames: [
        "org.junit.jupiter:junit-jupiter-api",
        "org.junit.jupiter:junit-jupiter-engine",
        "org.junit.platform:junit-platform-launcher",
      ],
      matchUpdateTypes: ["major"],
      enabled: false,
    },
    {
      matchPackageNames: ["dev.gradleplugins:gradle-api"],
      enabled: false,
    },
  ],
}
